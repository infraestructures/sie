    .box { border:1px solid #ddd; padding:12px; margin-bottom: 14px; }
    .suggest { display:none; position:absolute; z-index:9999; left:0; right:0; top:100%;
               background:#fff; border:1px solid #ccc; max-height:260px; overflow:auto; }
    .suggest div { padding:8px; cursor:pointer; border-bottom:1px solid #eee; }
    .suggest div:hover { background:#f3f3f3; }
    .err { background:#ffe4e4; padding:10px; margin-bottom:10px; }
  </style>
</head>
<body>

<h2>SolarForm (prova)</h2>

<?php foreach ($errors as $e): ?>
  <div class="err"><?= h($e) ?></div>
<?php endforeach; ?>

<form method="post" action="solarForm.php<?= $expedient_id ? '?id='.(int)$expedient_id : '' ?>">
  <input type="hidden" name="expedient_id" value="<?= (int)$expedient_id ?>">

  <div class="box">
    <h3>Dades generals</h3>

    <div class="row">
      <div style="flex:1">
        <label>Estat</label>
        <select name="estat">
          <option value="pendent" <?= ($exp['estat']==='pendent'?'selected':'') ?>>pendent</option>
          <option value="en_tramit" <?= ($exp['estat']==='en_tramit'?'selected':'') ?>>en_tramit</option>
          <option value="tancat" <?= ($exp['estat']==='tancat'?'selected':'') ?>>tancat</option>
        </select>
      </div>

      <div style="flex:2; position:relative;">
        <label>Centre (autocomplete)</label>
        <input type="text" id="centre_txt" name="centre_txt"
               value="<?= h($exp['centre_nom'] ?? '') ?>"
               autocomplete="off" placeholder="Escriu per cercar el centre...">
        <input type="hidden" id="centre_id" name="centre_id" value="<?= (int)($exp['centre_id'] ?? 0) ?>">
        <div id="centre_suggest" class="suggest"></div>
        <small>Has de seleccionar del desplegable (centre_id obligatori).</small>
      </div>
    </div>

    <div class="row">
      <div style="flex:1"><label>Data sol·licitud</label><input type="date" name="data_sollicitud" value="<?= h($exp['data_sollicitud']) ?>"></div>
      <div style="flex:2"><label>Obs sol·licitud</label><textarea name="obs_sollicitud" rows="2"><?= h($exp['obs_sollicitud']) ?></textarea></div>
    </div>

    <div class="row">
      <div style="flex:1"><label>Data topogràfic</label><input type="date" name="data_topografic" value="<?= h($exp['data_topografic']) ?>"></div>
      <div style="flex:2"><label>Obs topogràfic</label><textarea name="obs_topografic" rows="2"><?= h($exp['obs_topografic']) ?></textarea></div>
    </div>

    <div class="row">
      <div style="flex:1"><label>Data acord ple</label><input type="date" name="data_acord_ple" value="<?= h($exp['data_acord_ple']) ?>"></div>
      <div style="flex:2"><label>Obs acord ple</label><textarea name="obs_acord_ple" rows="2"><?= h($exp['obs_acord_ple']) ?></textarea></div>
    </div>
  </div>

  <div class="box">
    <h3>Solar</h3>

    <div class="row">
      <div style="flex:1">
        <label>Illa</label>
        <select id="illa_id" name="illa_id" onchange="onIllaChange()">
          <option value="">(selecciona)</option>
          <?php foreach ($illes as $il): ?>
            <option value="<?= (int)$il['id'] ?>" <?= ((string)$sol['illa_id']===(string)$il['id']?'selected':'') ?>>
              <?= h($il['nom']) ?>
            </option>
          <?php endforeach; ?>
        </select>
      </div>

      <div style="flex:1">
        <label>Municipi</label>
        <select id="municipi_id" name="municipi_id" data-selected="<?= h($sol['municipi_id']) ?>">
          <option value="">(selecciona)</option>
        </select>
      </div>
    </div>

    <div class="row">
      <div style="flex:1"><label>Ref cadastral</label><input name="ref_cadastral" value="<?= h($sol['ref_cadastral']) ?>"></div>
      <div style="flex:1"><label>Ref registral</label><input name="ref_registral" value="<?= h($sol['ref_registral']) ?>"></div>
      <div style="flex:1"><label>Superfície m²</label><input type="number" step="0.01" name="superficie_m2" value="<?= h($sol['superficie_m2']) ?>"></div>
    </div>

    <div class="row">
      <div style="flex:1"><label>Núm parcel·les</label><input type="number" name="num_parcelles" value="<?= h($sol['num_parcelles']) ?>"></div>
      <div style="flex:1">
        <label>&nbsp;</label>
        <label><input type="checkbox" name="requereix_agrupacio" value="1" <?= ((int)$sol['requereix_agrupacio']===1?'checked':'') ?>> Requereix agrupació</label>
        <label><input type="checkbox" name="requereix_segregacio" value="1" <?= ((int)$sol['requereix_segregacio']===1?'checked':'') ?>> Requereix segregació</label>
      </div>
      <div style="flex:2"><label>Límits</label><textarea name="limits_confrontacions" rows="2"><?= h($sol['limits_confrontacions']) ?></textarea></div>
    </div>

    <div class="row">
      <div style="flex:1"><label>Observacions parcel·les</label><textarea name="observacions_parcelles" rows="2"><?= h($sol['observacions_parcelles']) ?></textarea></div>
    </div>
  </div>

  <button type="submit">Guardar</button>
  <a href="solarListFiltro.php" style="margin-left:10px;">Tornar</a>
</form>

<script>
async function onIllaChange() {
  const illa = document.getElementById('illa_id').value;
  const municipi = document.getElementById('municipi_id');
  municipi.innerHTML = '<option value="">(selecciona)</option>';
  if (!illa) return;

  const r = await fetch('ajax_municipis.php?illa_id=' + encodeURIComponent(illa));
  const data = await r.json();
  data.forEach(m => {
    const opt = document.createElement('option');
    opt.value = m.id;
    opt.textContent = m.nom;
    municipi.appendChild(opt);
  });

  const sel = municipi.dataset.selected;
  if (sel) municipi.value = sel;
}

(function () {
  const input = document.getElementById('centre_txt');
  const hidden = document.getElementById('centre_id');
  const box = document.getElementById('centre_suggest');
  if (!input || !hidden || !box) return;

  let lastFetch = 0;
  let timer = null;
  let lastQuery = '';

  function hideBox(){ box.style.display='none'; box.innerHTML=''; }
  function showBox(){ box.style.display='block'; }

  function render(items){
    box.innerHTML = '';
    if (!items.length) {
      box.innerHTML = '<div style="padding:8px;color:#666;">Sense resultats</div>';
      showBox(); return;
    }
    items.forEach(it => {
      const row = document.createElement('div');
      row.textContent = it.nom;
      row.addEventListener('mousedown', e => {
        e.preventDefault();
        input.value = it.nom;
        hidden.value = it.id;
        hideBox();
      });
      box.appendChild(row);
    });
    showBox();
  }

  async function fetchCentres(q){
    const now = Date.now();
    lastFetch = now;
    const r = await fetch('ajax_centres.php?q=' + encodeURIComponent(q));
    const data = await r.json();
    if (lastFetch !== now) return;
    render(data);
  }

  input.addEventListener('input', () => {
    const q = input.value.trim();
    hidden.value = '';
    if (timer) clearTimeout(timer);
    if (q.length < 2) { hideBox(); return; }
    timer = setTimeout(() => {
      if (q === lastQuery) return;
      lastQuery = q;
      fetchCentres(q);
    }, 200);
  });

  document.addEventListener('click', (e) => {
    if (!box.contains(e.target) && e.target !== input) hideBox();
  });
})();

window.addEventListener('DOMContentLoaded', () => {
  if (document.getElementById('illa_id').value) onIllaChange();
});
</script>

</body>
</html>
