<?php
declare(strict_types=1);
include '../connectarBD.php';

function h($v): string {
  return htmlspecialchars((string)$v, ENT_QUOTES | ENT_SUBSTITUTE, 'UTF-8');
}

// ---- CARGA (modo edición) ----
$expedient_id = isset($_GET['id']) ? (int)$_GET['id'] : 0;

$exp = [
  'id' => 0,
  'centre_id' => 0,
  'centre_nom' => '',
  'estat' => 'pendent',
  'data_sollicitud' => '',
  'obs_sollicitud' => '',
  'data_topografic' => '',
  'obs_topografic' => '',
  'data_acord_ple' => '',
  'obs_acord_ple' => '',
];

$sol = [
  'id' => 0,
  'illa_id' => '',
  'municipi_id' => '',
  'ref_cadastral' => '',
  'ref_registral' => '',
  'superficie_m2' => '',
  'num_parcelles' => '',
  'requereix_agrupacio' => 0,
  'requereix_segregacio' => 0,
  'limits_confrontacions' => '',
  'observacions_parcelles' => '',
];

$errors = [];
$ok = false;

// ---- SAVE ----
if ($_SERVER['REQUEST_METHOD'] === 'POST') {
  // Debug opcional (quita si molesta)
  // echo "<pre>POST RECIBIDO\n"; print_r($_POST); echo "</pre>"; exit;

  $expedient_id = (int)($_POST['expedient_id'] ?? 0);

  $centre_id = (int)($_POST['centre_id'] ?? 0);
  $estat = $_POST['estat'] ?? 'pendent';

  if ($centre_id <= 0) {
    $errors[] = "Has de seleccionar un centre de la llista (centre_id és obligatori).";
  }

  // Expedient fields
  $data_sollicitud = ($_POST['data_sollicitud'] ?? '') ?: null;
  $obs_sollicitud  = ($_POST['obs_sollicitud'] ?? '') ?: null;
  $data_topografic = ($_POST['data_topografic'] ?? '') ?: null;
  $obs_topografic  = ($_POST['obs_topografic'] ?? '') ?: null;
  $data_acord_ple  = ($_POST['data_acord_ple'] ?? '') ?: null;
  $obs_acord_ple   = ($_POST['obs_acord_ple'] ?? '') ?: null;

  // Solar fields
  $illa_id = ($_POST['illa_id'] ?? '') !== '' ? (int)$_POST['illa_id'] : null;
  $municipi_id = ($_POST['municipi_id'] ?? '') !== '' ? (int)$_POST['municipi_id'] : null;

  $ref_cadastral = ($_POST['ref_cadastral'] ?? '') ?: null;
  $ref_registral = ($_POST['ref_registral'] ?? '') ?: null;
  $superficie_m2 = ($_POST['superficie_m2'] ?? '') !== '' ? (float)$_POST['superficie_m2'] : null;

  $num_parcelles = ($_POST['num_parcelles'] ?? '') !== '' ? (int)$_POST['num_parcelles'] : null;
  $requereix_agrupacio  = isset($_POST['requereix_agrupacio']) ? 1 : 0;
  $requereix_segregacio = isset($_POST['requereix_segregacio']) ? 1 : 0;

  $limits_confrontacions = ($_POST['limits_confrontacions'] ?? '') ?: null;
  $observacions_parcelles = ($_POST['observacions_parcelles'] ?? '') ?: null;

  // Validar que centre_id existe (FK-friendly)
  if (!$errors) {
    $stmt = $connexio->prepare("SELECT id FROM centres WHERE id = ? LIMIT 1");
    if (!$stmt) $errors[] = "Prepare centres: " . $connexio->error;
    else {
      $stmt->bind_param("i", $centre_id);
      $stmt->execute();
      $r = $stmt->get_result()->fetch_assoc();
      if (!$r) $errors[] = "El centre seleccionat no existeix (id=$centre_id).";
    }
  }

  if (!$errors) {
    $connexio->begin_transaction();

    try {
      // 1) Insert/Update expedient
      if ($expedient_id > 0) {
        $sql = "UPDATE expedients_solar
                SET centre_id=?, estat=?,
                    data_sollicitud=?, obs_sollicitud=?,
                    data_topografic=?, obs_topografic=?,
                    data_acord_ple=?, obs_acord_ple=?
                WHERE id=?";
        $stmt = $connexio->prepare($sql);
        if (!$stmt) throw new Exception("Prepare expedient UPDATE: " . $connexio->error);

        $stmt->bind_param(
          "isssssssi",
          $centre_id, $estat,
          $data_sollicitud, $obs_sollicitud,
          $data_topografic, $obs_topografic,
          $data_acord_ple, $obs_acord_ple,
          $expedient_id
        );
        if (!$stmt->execute()) throw new Exception("Execute expedient UPDATE: " . $stmt->error);

      } else {
        $sql = "INSERT INTO expedients_solar
                (centre_id, estat, data_sollicitud, obs_sollicitud, data_topografic, obs_topografic, data_acord_ple, obs_acord_ple)
                VALUES (?,?,?,?,?,?,?,?)";
        $stmt = $connexio->prepare($sql);
        if (!$stmt) throw new Exception("Prepare expedient INSERT: " . $connexio->error);

        $stmt->bind_param(
          "isssssss",
          $centre_id, $estat,
          $data_sollicitud, $obs_sollicitud,
          $data_topografic, $obs_topografic,
          $data_acord_ple, $obs_acord_ple
        );
        if (!$stmt->execute()) throw new Exception("Execute expedient INSERT: " . $stmt->error);

        $expedient_id = (int)$connexio->insert_id;
      }

      // 2) ¿Ya hay solar principal para este expediente?
      $solar_id = 0;
      $sql = "
        SELECT ass.solar_id
        FROM actuacions_solar a
        JOIN actuacions_solar_solars ass ON ass.actuacio_solar_id = a.id AND ass.rol='principal'
        WHERE a.expedient_id = ?
        LIMIT 1";
      $stmt = $connexio->prepare($sql);
      if (!$stmt) throw new Exception("Prepare find solar: " . $connexio->error);
      $stmt->bind_param("i", $expedient_id);
      $stmt->execute();
      $row = $stmt->get_result()->fetch_assoc();
      if ($row) $solar_id = (int)$row['solar_id'];

      // 3) Insert/Update solar
      if ($solar_id > 0) {
        $sql = "UPDATE solars
                SET municipi_id=?, illa_id=?,
                    ref_cadastral=?, ref_registral=?, superficie_m2=?,
                    num_parcelles=?, requereix_agrupacio=?, requereix_segregacio=?,
                    limits_confrontacions=?, observacions_parcelles=?
                WHERE id=?";
        $stmt = $connexio->prepare($sql);
        if (!$stmt) throw new Exception("Prepare solar UPDATE: " . $connexio->error);

        $stmt->bind_param(
          "iissdiiissi",
          $municipi_id, $illa_id,
          $ref_cadastral, $ref_registral, $superficie_m2,
          $num_parcelles, $requereix_agrupacio, $requereix_segregacio,
          $limits_confrontacions, $observacions_parcelles,
          $solar_id
        );
        if (!$stmt->execute()) throw new Exception("Execute solar UPDATE: " . $stmt->error);

      } else {
        $sql = "INSERT INTO solars
                (municipi_id, illa_id, ref_cadastral, ref_registral, superficie_m2,
                 num_parcelles, requereix_agrupacio, requereix_segregacio,
                 limits_confrontacions, observacions_parcelles)
                VALUES (?,?,?,?,?,?,?,?,?,?)";
        $stmt = $connexio->prepare($sql);
        if (!$stmt) throw new Exception("Prepare solar INSERT: " . $connexio->error);

        $stmt->bind_param(
          "iissdiiiss",
          $municipi_id, $illa_id,
          $ref_cadastral, $ref_registral, $superficie_m2,
          $num_parcelles, $requereix_agrupacio, $requereix_segregacio,
          $limits_confrontacions, $observacions_parcelles
        );
        if (!$stmt->execute()) throw new Exception("Execute solar INSERT: " . $stmt->error);

        $solar_id = (int)$connexio->insert_id;

        // 4) Actuació mínima + puente principal
        $sql = "INSERT INTO actuacions_solar (expedient_id, tipus) VALUES (?, 'altres')";
        $stmt = $connexio->prepare($sql);
        if (!$stmt) throw new Exception("Prepare actuacio INSERT: " . $connexio->error);
        $stmt->bind_param("i", $expedient_id);
        if (!$stmt->execute()) throw new Exception("Execute actuacio INSERT: " . $stmt->error);
        $act_id = (int)$connexio->insert_id;

        $sql = "INSERT INTO actuacions_solar_solars (actuacio_solar_id, solar_id, rol)
                VALUES (?, ?, 'principal')";
        $stmt = $connexio->prepare($sql);
        if (!$stmt) throw new Exception("Prepare puente INSERT: " . $connexio->error);
        $stmt->bind_param("ii", $act_id, $solar_id);
        if (!$stmt->execute()) throw new Exception("Execute puente INSERT: " . $stmt->error);
      }

      $connexio->commit();
      header("Location: solarForm.php?id=" . $expedient_id);
      exit;

    } catch (Throwable $e) {
      $connexio->rollback();
      $errors[] = "ERROR GUARDANT: " . $e->getMessage();
    }
  }
}

// ---- RECARGAR datos si edición ----
if ($expedient_id > 0) {
  // Expediente + nombre centro
  $sql = "SELECT e.*, c.Centre AS centre_nom
          FROM expedients_solar e
          JOIN centres c ON c.id = e.centre_id
          WHERE e.id = ?";
  $stmt = $connexio->prepare($sql);
  if ($stmt) {
    $stmt->bind_param("i", $expedient_id);
    $stmt->execute();
    $row = $stmt->get_result()->fetch_assoc();
    if ($row) {
      $exp = array_merge($exp, $row);
    }
  }

  // Solar principal
  $sql = "
    SELECT s.*
    FROM actuacions_solar a
    JOIN actuacions_solar_solars ass ON ass.actuacio_solar_id = a.id AND ass.rol='principal'
    JOIN solars s ON s.id = ass.solar_id
    WHERE a.expedient_id = ?
    LIMIT 1";
  $stmt = $connexio->prepare($sql);
  if ($stmt) {
    $stmt->bind_param("i", $expedient_id);
    $stmt->execute();
    $row = $stmt->get_result()->fetch_assoc();
    if ($row) {
      $sol = array_merge($sol, $row);
    }
  }
}

// Illes para combo
$illes = $connexio->query("SELECT id, nom FROM illa ORDER BY nom")->fetch_all(MYSQLI_ASSOC);
?>
<!doctype html>
<html>
<head>
